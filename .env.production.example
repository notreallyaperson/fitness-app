# Copy to .env.production on the server and fill in (this file is gitignored).
# Used both as docker compose build args (NEXT_PUBLIC_*) and container runtime env.

# Public — baked into the client bundle at build time (safe to expose):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_APP_URL=https://exercise.example.com

# Secret — runtime only, never sent to the browser:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
